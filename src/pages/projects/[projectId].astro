---
import AppLayout from "../../layouts/AppLayout.astro";
import { ProjectService } from "../../lib/services/project.service";
import Button from "../../components/ui/Button.astro";
import Input from "../../components/ui/Input.astro";
import Modal from "../../components/ui/Modal.astro";

const { projectId } = Astro.params;
let project;

if (projectId) {
  try {
    project = await ProjectService.getProjectById(projectId);
  } catch (error) {
    console.error("Failed to fetch project:", error);
  }
}

if (!project) {
  return Astro.redirect("/404");
}

const lists = project.lists || [];
const colorOptions = [
  "#6b7280",
  "#ef4444",
  "#f97316",
  "#eab308",
  "#22c55e",
  "#06b6d4",
  "#3b82f6",
  "#8b5cf6",
  "#ec4899",
];
---

<AppLayout title={project.name}>
  <div class="h-full min-h-0 flex flex-col">
    <!-- Page header -->
    <div class="flex items-start justify-between gap-4 mb-6 px-4">
      <div class="min-w-0">
        <h1 class="text-2xl font-bold text-ink-900 dark:text-ink-100 truncate">
          {project.name}
        </h1>
        <p class="text-sm text-ink-500 dark:text-ink-300 line-clamp-1">
          {project.description}
        </p>
      </div>

      <div class="flex gap-2">
        <Button
          variant="secondary"
          onclick="document.getElementById('create_list_modal').showModal()"
        >
          Add list
        </Button>
      </div>
    </div>

    <!-- Board surface (fills remaining height) -->
    <div class="flex-1 min-h-0 px-4 pb-6">
      <div
        class="h-full min-h-0 rounded-3xl bg-surface-50 dark:bg-ink-900
               border border-ink-100/70 dark:border-ink-700/60
               shadow-card overflow-hidden"
      >
        <div class="h-full min-h-0 overflow-x-auto overflow-y-hidden">
          <div
            class="inline-flex min-w-full h-full min-h-0 gap-4 items-stretch p-4 pb-6"
            id="board-lists"
          >
            {
              lists
                .sort((a, b) => a.order - b.order)
                .map((list) => (
                  <div
                    class="w-80 flex-shrink-0 flex flex-col h-full min-h-0 list-container select-none"
                    data-id={list.id}
                    draggable="true"
                  >
                    <div
                      class="rounded-3xl bg-surface-50 dark:bg-ink-900
                             border border-ink-100/70 dark:border-ink-700/60
                             shadow-card overflow-hidden flex flex-col h-full min-h-0"
                    >
                      <!-- Accent strip -->
                      <div
                        class="h-1 w-full"
                        style={`background-color: ${list.color || "#6b7280"}`}
                        aria-hidden="true"
                      />

                      <!-- Header -->
                      <div
                        class="px-4 py-3
                               bg-surface-100 dark:bg-ink-800/60
                               border-b border-ink-100/70 dark:border-ink-700/60
                               flex items-center justify-between gap-2
                               handle cursor-grab active:cursor-grabbing"
                      >
                        <div class="min-w-0 flex items-center gap-2">
                          <span
                            class="h-2.5 w-2.5 rounded-full flex-none"
                            style={`background-color: ${list.color || "#6b7280"}`}
                            aria-hidden="true"
                          />
                          <h3 class="text-sm font-semibold text-ink-900 dark:text-ink-100 truncate">
                            {list.title}
                          </h3>

                          <!-- Count pill (placeholder) -->
                          <span
                            class="ml-1 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                                   bg-surface-200/70 text-ink-600 border border-ink-100/70
                                   dark:bg-ink-800/60 dark:text-ink-300 dark:border-ink-700/60"
                          >
                            0
                          </span>
                        </div>

                        <!-- Menu -->
                        <div class="relative menu-container flex items-center">
                          <button
                            type="button"
                            class="menu-trigger h-9 w-9 grid place-items-center rounded-xl transition-colors
                                   text-ink-500 hover:text-ink-900 hover:bg-ink-100
                                   dark:text-ink-400 dark:hover:text-ink-100 dark:hover:bg-ink-800
                                   focus:outline-none focus-visible:ring-2 focus-visible:ring-peach-300/70"
                            onclick="toggleMenu(event, this)"
                            aria-label="List options"
                          >
                            <!-- vertical dots look cleaner -->
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              class="h-5 w-5 pointer-events-none"
                              viewBox="0 0 20 20"
                              fill="currentColor"
                            >
                              <path d="M10 4.25a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM10 8.75a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM10 13.25a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5z" />
                            </svg>
                          </button>

                          <div
                            class="menu-dropdown absolute right-0 top-full mt-2 w-52 hidden z-50 overflow-hidden
                                   rounded-2xl shadow-card
                                   bg-surface-50 dark:bg-ink-800
                                   border border-ink-100 dark:border-ink-700
                                   ring-1 ring-black/5 dark:ring-white/10"
                          >
                            <div
                              class="px-3 py-2 text-[0.65rem] tracking-wider font-semibold uppercase
                                     text-ink-500 dark:text-ink-300
                                     border-b border-ink-100/70 dark:border-ink-700/70
                                     bg-surface-100 dark:bg-ink-800/60"
                            >
                              List actions
                            </div>

                            <button
                              type="button"
                              onclick={`openEditListModal('${list.id}', '${list.title}', '${list.color || "#6b7280"}')`}
                              class="w-full text-left px-3 py-2.5 text-sm
                                     text-ink-800 dark:text-ink-100
                                     hover:bg-peach-50 dark:hover:bg-ink-700/70
                                     transition-colors flex items-center gap-2"
                            >
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-4 w-4 text-ink-400 dark:text-ink-500"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="1.5"
                                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                                />
                              </svg>
                              Edit / Rename
                            </button>

                            <button
                              type="button"
                              onclick={`deleteList('${list.id}')`}
                              class="w-full text-left px-3 py-2.5 text-sm
                                     text-red-700 dark:text-red-300
                                     hover:bg-red-50 dark:hover:bg-ink-700/70
                                     transition-colors flex items-center gap-2"
                            >
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-4 w-4 opacity-80"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="1.5"
                                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                                />
                              </svg>
                              Delete list
                            </button>
                          </div>
                        </div>
                      </div>

                      <!-- Body (scroll area) -->
                      <div class="p-3 flex-1 min-h-0 overflow-y-auto">
                        <div
                          class="rounded-2xl border border-dashed border-ink-200/70 dark:border-ink-700/60
                                 bg-surface-100/70 dark:bg-ink-800/40
                                 px-4 py-7 text-center"
                        >
                          <p class="text-xs font-medium text-ink-500 dark:text-ink-300">
                            Drop tasks here
                          </p>
                          <p class="text-[0.7rem] text-ink-400 dark:text-ink-500 mt-1">
                            Drag items into this list
                          </p>
                        </div>
                      </div>

                    </div>
                  </div>
                ))
            }

            <!-- Add List "Card" -->
            <button
              type="button"
              onclick="document.getElementById('create_list_modal').showModal()"
              class="w-80 flex-shrink-0 h-full min-h-0
                     rounded-3xl border border-dashed border-ink-200/70 dark:border-ink-700/60
                     bg-surface-50 dark:bg-ink-900
                     hover:bg-surface-100 dark:hover:bg-ink-800/40
                     transition-colors
                     flex items-center justify-center"
              aria-label="Create new list"
            >
              <div class="text-center px-6">
                <div
                  class="mx-auto mb-3 h-10 w-10 rounded-2xl
                         bg-peach-50 dark:bg-ink-800/60
                         flex items-center justify-center
                         ring-1 ring-ink-100/70 dark:ring-ink-700/60"
                >
                  <span class="text-peach-600 dark:text-peach-300 text-xl leading-none">+</span>
                </div>
                <p class="text-sm font-semibold text-ink-900 dark:text-ink-100">
                  New list
                </p>
                <p class="text-xs text-ink-500 dark:text-ink-300 mt-1">
                  Add a column to your board
                </p>
              </div>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Create List Modal -->
  <Modal id="create_list_modal" title="Create New List">
    <form id="create_list_form" class="space-y-6">
      <Input
        name="title"
        label="List Title"
        placeholder="e.g. Testing, Blocked"
        required
      />

      <div>
        <label class="text-sm font-medium text-ink-600 dark:text-ink-300 ml-1 mb-2 block">
          List color
        </label>

        <div class="flex flex-wrap gap-2">
          {colorOptions.map((c, i) => (
            <label class="cursor-pointer">
              <input
                type="radio"
                name="color"
                value={c}
                class="peer sr-only"
                checked={i === 0 ? true : undefined}
              />
              <div
                class="w-7 h-7 rounded-full
                       ring-1 ring-ink-200/70 dark:ring-ink-700/60
                       peer-checked:ring-2 peer-checked:ring-peach-300/70
                       peer-checked:ring-offset-2 peer-checked:ring-offset-surface-50
                       dark:peer-checked:ring-offset-ink-900
                       transition"
                style={`background-color: ${c}`}
                aria-label={`Color ${c}`}
              ></div>
            </label>
          ))}
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <Button
          variant="ghost"
          type="button"
          onclick="document.getElementById('create_list_modal').close()"
        >
          Cancel
        </Button>
        <Button type="submit">Create list</Button>
      </div>
    </form>
  </Modal>

  <!-- Edit List Modal -->
  <Modal id="edit_list_modal" title="Edit List">
    <form id="edit_list_form" class="space-y-6">
      <input type="hidden" name="listId" id="edit_list_id" />

      <Input
        name="title"
        id="edit_list_title"
        label="List Title"
        required
      />

      <div>
        <label class="text-sm font-medium text-ink-600 dark:text-ink-300 ml-1 mb-2 block">
          List color
        </label>

        <div class="flex flex-wrap gap-2">
          {colorOptions.map((c) => (
            <label class="cursor-pointer">
              <input type="radio" name="color" value={c} class="peer sr-only" />
              <div
                class="w-7 h-7 rounded-full
                       ring-1 ring-ink-200/70 dark:ring-ink-700/60
                       peer-checked:ring-2 peer-checked:ring-peach-300/70
                       peer-checked:ring-offset-2 peer-checked:ring-offset-surface-50
                       dark:peer-checked:ring-offset-ink-900
                       transition"
                style={`background-color: ${c}`}
                aria-label={`Color ${c}`}
              ></div>
            </label>
          ))}
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <Button
          variant="ghost"
          type="button"
          onclick="document.getElementById('edit_list_modal').close()"
        >
          Cancel
        </Button>
        <Button type="submit">Save changes</Button>
      </div>
    </form>
  </Modal>
</AppLayout>

<script define:vars={{ projectId: project._id }}>
  // List Creation
  const createForm = document.getElementById("create_list_form");
  createForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch(`/api/projects/${projectId}/lists`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (res.ok) window.location.reload();
      else alert("Failed to create list");
    } catch (err) {
      console.error(err);
      alert("Error creating list");
    }
  });

  // Edit List
  const editForm = document.getElementById("edit_list_form");
  editForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);
    const listId = data.listId;

    try {
      const res = await fetch(`/api/projects/${projectId}/lists/${listId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (res.ok) window.location.reload();
      else alert("Failed to update list");
    } catch (err) {
      console.error(err);
      alert("Error updating list");
    }
  });

  window.openEditListModal = (id, title, color) => {
    closeAllMenus();

    const modal = document.getElementById("edit_list_modal");
    const form = document.getElementById("edit_list_form");

    document.getElementById("edit_list_id").value = id;
    document.getElementById("edit_list_title").value = title;

    const colorRadio = form.querySelector(
      `input[name="color"][value="${color}"]`,
    );
    if (colorRadio) colorRadio.checked = true;

    modal.showModal();
  };

  // Menu Handling
  window.toggleMenu = (e, btn) => {
    e.preventDefault();
    e.stopPropagation();

    const dropdown = btn.nextElementSibling;
    if (!dropdown) return;

    const willOpen = dropdown.classList.contains("hidden");
    closeAllMenus();
    if (willOpen) dropdown.classList.remove("hidden");
  };

  function closeAllMenus() {
    document
      .querySelectorAll(".menu-dropdown")
      .forEach((el) => el.classList.add("hidden"));
  }

  document.addEventListener("click", (e) => {
    if (!e.target.closest(".menu-container")) closeAllMenus();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeAllMenus();
  });

  // Delete List
  window.deleteList = async (listId) => {
    if (!confirm("Are you sure you want to delete this list?")) return;
    try {
      const res = await fetch(`/api/projects/${projectId}/lists/${listId}`, {
        method: "DELETE",
      });
      if (res.ok) window.location.reload();
      else alert("Failed to delete list");
    } catch (err) {
      console.error(err);
      alert("Error deleting list");
    }
  };

  // Drag & drop lists
  const container = document.getElementById("board-lists");
  let draggable = null;

  // Initial setup: ensure list containers are properly configured
  // HTML5 DnD requires draggable="true" on the element, but we want to restrict
  // drag initiation to the handle. A common pattern is to use mousedown on the handle
  // to set draggable=true on the container, and reset it otherwise.
  
  document.addEventListener('mousedown', (e) => {
      const target = e.target;
      // We are looking for clicks within our list containers
      const listEl = target.closest('.list-container');
      if (!listEl) return;

      // Check if the click started on a handle (or inside it)
      const handle = target.closest('.handle');

      if (handle) {
          listEl.setAttribute('draggable', 'true');
      } else {
          // If clicking elsewhere (e.g. content, buttons), disable drag
          listEl.setAttribute('draggable', 'false');
      }
  });

  if (container) {
      container.addEventListener("dragstart", (e) => {
        // e.target is the element being dragged (the list-container)
        const target = e.target;
        if (!target.classList || !target.classList.contains('list-container')) return;
        
        draggable = target;
        draggable.classList.add("opacity-50");
        e.dataTransfer.effectAllowed = "move";
        // Required for Firefox
        e.dataTransfer.setData('text/plain', draggable.dataset.id);
      });

      container.addEventListener("dragend", async (e) => {
        if (!draggable) return;
        draggable.classList.remove("opacity-50");
        draggable.removeAttribute('draggable'); // Reset state
        
        // Calculate new order
        const listIds = Array.from(
          container.querySelectorAll(".list-container"),
        ).map((el) => el.getAttribute('data-id'));

        try {
          await fetch(`/api/projects/${projectId}/lists`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ listIds }),
          });
        } catch (err) {
          console.error("Failed to save order", err);
        }

        draggable = null;
      });

      container.addEventListener("dragover", (e) => {
        e.preventDefault();
        if (!draggable) return;

        const afterElement = getDragAfterElement(container, e.clientX);
        const newListBtn = container.querySelector("button[onclick*='create_list_modal']");
        
        if (afterElement == null) {
            if (newListBtn) {
                container.insertBefore(draggable, newListBtn);
            } else {
                container.appendChild(draggable);
            }
        } else {
            container.insertBefore(draggable, afterElement);
        }
      });
  }

  function getDragAfterElement(container, x) {
    const draggableElements = [
      ...container.querySelectorAll(".list-container:not(.opacity-50)"),
    ];

    return draggableElements.reduce(
      (closest, child) => {
        const box = child.getBoundingClientRect();
        const offset = x - box.left - box.width / 2;
        if (offset < 0 && offset > closest.offset) {
          return { offset: offset, element: child };
        }
        return closest;
      },
      { offset: Number.NEGATIVE_INFINITY, element: null },
    ).element;
  }
</script>