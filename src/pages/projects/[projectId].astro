---
import AppLayout from "../../layouts/AppLayout.astro";
import { ProjectService } from "../../lib/services/project.service";
import { IssueService } from "../../lib/services/issue.service";
import Button from "../../components/ui/Button.astro";
import Input from "../../components/ui/Input.astro";
import Modal from "../../components/ui/Modal.astro";

const { projectId } = Astro.params;
let project;
let issues = [];
let issuesByList = {};

if (projectId) {
  try {
    project = await ProjectService.getProjectById(projectId);
    issues = await IssueService.getIssuesByProject(projectId);
    
    issues.forEach(issue => {
      if (!issuesByList[issue.listId]) {
        issuesByList[issue.listId] = [];
      }
      issuesByList[issue.listId].push(issue);
    });
    
    // Sort issues by order
    Object.keys(issuesByList).forEach(listId => {
      issuesByList[listId].sort((a, b) => a.order - b.order);
    });

  } catch (error) {
    console.error("Failed to fetch project:", error);
  }
}

if (!project) {
  return Astro.redirect("/404");
}

const lists = project.lists || [];
const colorOptions = [
  "#6b7280",
  "#ef4444",
  "#f97316",
  "#eab308",
  "#22c55e",
  "#06b6d4",
  "#3b82f6",
  "#8b5cf6",
  "#ec4899",
];
---

<AppLayout title={project.name}>
  <div class="h-full min-h-0 flex flex-col">
    <!-- Page header -->
    <div class="flex items-start justify-between gap-4 mb-6 px-4">
      <div class="min-w-0">
        <h1 class="text-2xl font-bold text-ink-900 dark:text-ink-100 truncate">
          {project.name}
        </h1>
        <div class="flex items-center gap-2 mt-1">
             <a href={`/projects/${projectId}`} class="px-3 py-1 bg-peach-500 text-white rounded-lg text-sm font-medium">
                Board
             </a>
             <a href={`/projects/${projectId}/issues`} class="px-3 py-1 text-ink-500 dark:text-ink-400 hover:bg-surface-100 dark:hover:bg-ink-800 rounded-lg text-sm transition-colors">
                List
             </a>
        </div>
      </div>

      <div class="flex gap-2 items-center">
        <div class="relative w-48">
             <input 
                type="text" 
                id="issue-search" 
                placeholder="Search issues..." 
                class="w-full h-10 px-3 pr-8 rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 text-sm focus:outline-none focus:ring-2 focus:ring-peach-500/50"
                oninput="filterIssues()"
             />
             <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 absolute right-3 top-3 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
             </svg>
        </div>
        <select 
            id="issue-priority-filter" 
            class="h-10 px-3 rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 text-sm focus:outline-none focus:ring-2 focus:ring-peach-500/50"
            onchange="filterIssues()"
        >
            <option value="">All Priorities</option>
            <option value="Low">Low</option>
            <option value="Medium">Medium</option>
            <option value="High">High</option>
        </select>
        <div class="h-6 w-px bg-ink-200 dark:bg-ink-700 mx-1"></div>
        <Button
          variant="secondary"
          onclick="document.getElementById('create_list_modal').showModal()"
        >
          Add list
        </Button>
      </div>
    </div>

    <!-- Board surface (fills remaining height) -->
    <div class="flex-1 min-h-0 px-4 pb-6">
      <div
        class="h-full min-h-0 rounded-3xl bg-surface-50 dark:bg-ink-900
               border border-ink-100/70 dark:border-ink-700/60
               shadow-card overflow-hidden"
      >
        <div class="h-full min-h-0 overflow-x-auto overflow-y-hidden">
          <div
            class="inline-flex min-w-full h-full min-h-0 gap-4 items-stretch p-4 pb-6"
            id="board-lists"
          >
            {
              lists
                .sort((a, b) => a.order - b.order)
                .map((list) => (
                  <div
                    class="w-80 flex-shrink-0 flex flex-col h-full min-h-0 list-container select-none"
                    data-id={list.id}
                    draggable="true"
                  >
                    <div
                      class="rounded-3xl bg-surface-50 dark:bg-ink-900
                             border border-ink-100/70 dark:border-ink-700/60
                             shadow-card overflow-hidden flex flex-col h-full min-h-0"
                    >
                      <!-- Accent strip -->
                      <div
                        class="h-1 w-full"
                        style={`background-color: ${list.color || "#6b7280"}`}
                        aria-hidden="true"
                      />

                      <!-- Header -->
                      <div
                        class="px-4 py-3
                               bg-surface-100 dark:bg-ink-800/60
                               border-b border-ink-100/70 dark:border-ink-700/60
                               flex items-center justify-between gap-2
                               handle cursor-grab active:cursor-grabbing"
                      >
                        <div class="min-w-0 flex items-center gap-2">
                          <span
                            class="h-2.5 w-2.5 rounded-full flex-none"
                            style={`background-color: ${list.color || "#6b7280"}`}
                            aria-hidden="true"
                          />
                          <h3 class="text-sm font-semibold text-ink-900 dark:text-ink-100 truncate">
                            {list.title}
                          </h3>

                          <!-- Count pill (placeholder) -->
                          <span
                            class="ml-1 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                                   bg-surface-200/70 text-ink-600 border border-ink-100/70
                                   dark:bg-ink-800/60 dark:text-ink-300 dark:border-ink-700/60"
                          >
                            0
                          </span>
                        </div>

                        <!-- Menu -->
                        <div class="relative menu-container flex items-center">
                          <button
                            type="button"
                            class="menu-trigger h-9 w-9 grid place-items-center rounded-xl transition-colors
                                   text-ink-500 hover:text-ink-900 hover:bg-ink-100
                                   dark:text-ink-400 dark:hover:text-ink-100 dark:hover:bg-ink-800
                                   focus:outline-none focus-visible:ring-2 focus-visible:ring-peach-300/70"
                            onclick="toggleMenu(event, this)"
                            aria-label="List options"
                          >
                            <!-- vertical dots look cleaner -->
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              class="h-5 w-5 pointer-events-none"
                              viewBox="0 0 20 20"
                              fill="currentColor"
                            >
                              <path d="M10 4.25a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM10 8.75a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5zM10 13.25a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5z" />
                            </svg>
                          </button>

                          <div
                            class="menu-dropdown absolute right-0 top-full mt-2 w-52 hidden z-50 overflow-hidden
                                   rounded-2xl shadow-card
                                   bg-surface-50 dark:bg-ink-800
                                   border border-ink-100 dark:border-ink-700
                                   ring-1 ring-black/5 dark:ring-white/10"
                          >
                            <div
                              class="px-3 py-2 text-[0.65rem] tracking-wider font-semibold uppercase
                                     text-ink-500 dark:text-ink-300
                                     border-b border-ink-100/70 dark:border-ink-700/70
                                     bg-surface-100 dark:bg-ink-800/60"
                            >
                              List actions
                            </div>

                            <button
                              type="button"
                              onclick={`openEditListModal('${list.id}', '${list.title}', '${list.color || "#6b7280"}')`}
                              class="w-full text-left px-3 py-2.5 text-sm
                                     text-ink-800 dark:text-ink-100
                                     hover:bg-peach-50 dark:hover:bg-ink-700/70
                                     transition-colors flex items-center gap-2"
                            >
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-4 w-4 text-ink-400 dark:text-ink-500"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="1.5"
                                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                                />
                              </svg>
                              Edit / Rename
                            </button>

                            <button
                              type="button"
                              onclick={`deleteList('${list.id}')`}
                              class="w-full text-left px-3 py-2.5 text-sm
                                     text-red-700 dark:text-red-300
                                     hover:bg-red-50 dark:hover:bg-ink-700/70
                                     transition-colors flex items-center gap-2"
                            >
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-4 w-4 opacity-80"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="1.5"
                                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                                />
                              </svg>
                              Delete list
                            </button>
                          </div>
                        </div>
                      </div>

                      <!-- Body (scroll area) -->
                      <div class="p-3 flex-1 min-h-0 overflow-y-auto list-body" data-list-id={list.id}>
                        {
                          issuesByList[list.id] && issuesByList[list.id].length > 0 ? (
                            issuesByList[list.id].map((issue) => (
                              <div
                                class="issue-card bg-surface-50 dark:bg-ink-800 p-3 rounded-xl mb-2
                                       border border-ink-200/50 dark:border-ink-700/50
                                       shadow-sm hover:shadow transition-shadow
                                       cursor-pointer group relative"
                                data-issue-id={issue._id}
                                draggable="true"
                                onclick={`openEditIssueModal('${issue._id}')`}
                              >
                                <div class="flex justify-between items-start mb-1">
                                    <span class="text-sm font-medium text-ink-900 dark:text-ink-100 line-clamp-2 leading-snug">
                                        {issue.title}
                                    </span>
                                </div>
                                <div class="flex justify-between items-center mt-2">
                                     <div class="flex gap-1">
                                         {issue.labels && issue.labels.map(label => (
                                             <span class="text-[10px] px-1.5 py-0.5 rounded bg-surface-200 dark:bg-ink-700 text-ink-600 dark:text-ink-300">
                                                 {label}
                                             </span>
                                         ))}
                                     </div>
                                     <span class={`text-[10px] px-1.5 py-0.5 rounded font-medium ${
                                        issue.priority === 'High' ? 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300' :
                                        issue.priority === 'Medium' ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300' :
                                        'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300'
                                     }`}>
                                        {issue.priority}
                                     </span>
                                </div>
                              </div>
                            ))
                          ) : null
                        }
                      </div>

                      <!-- Footer -->
                      <div class="p-3 pt-0">
                         <button
                            class="w-full py-2 rounded-xl
                                   text-sm font-medium text-ink-500 hover:text-ink-900
                                   hover:bg-ink-100 dark:text-ink-400 dark:hover:text-ink-100
                                   dark:hover:bg-ink-800/60 transition-colors flex items-center justify-start px-2 gap-2"
                            onclick={`openCreateIssueModal('${list.id}')`}
                         >
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                            </svg>
                            Add issue
                         </button>
                      </div>

                    </div>
                  </div>
                ))
            }

            <!-- Add List "Card" -->
            <button
              type="button"
              onclick="document.getElementById('create_list_modal').showModal()"
              class="w-80 flex-shrink-0 h-full min-h-0
                     rounded-3xl border border-dashed border-ink-200/70 dark:border-ink-700/60
                     bg-surface-50 dark:bg-ink-900
                     hover:bg-surface-100 dark:hover:bg-ink-800/40
                     transition-colors
                     flex items-center justify-center"
              aria-label="Create new list"
            >
              <div class="text-center px-6">
                <div
                  class="mx-auto mb-3 h-10 w-10 rounded-2xl
                         bg-peach-50 dark:bg-ink-800/60
                         flex items-center justify-center
                         ring-1 ring-ink-100/70 dark:ring-ink-700/60"
                >
                  <span class="text-peach-600 dark:text-peach-300 text-xl leading-none">+</span>
                </div>
                <p class="text-sm font-semibold text-ink-900 dark:text-ink-100">
                  New list
                </p>
                <p class="text-xs text-ink-500 dark:text-ink-300 mt-1">
                  Add a column to your board
                </p>
              </div>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Create Issue Modal -->
  <Modal id="create_issue_modal" title="Create New Issue">
    <form id="create_issue_form" class="space-y-4">
      <input type="hidden" name="listId" id="create_issue_list_id" />
      <Input name="title" label="Title" placeholder="What needs to be done?" required />
      
      <div>
        <label class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1">Priority</label>
        <select name="priority" class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50">
            <option value="Low">Low</option>
            <option value="Medium" selected>Medium</option>
            <option value="High">High</option>
        </select>
      </div>
      
      <div class="flex justify-end gap-2 pt-4">
        <Button variant="secondary" onclick="document.getElementById('create_issue_modal').close()">Cancel</Button>
        <Button type="submit">Create Issue</Button>
      </div>
    </form>
  </Modal>

  <!-- Edit Issue Modal -->
  <Modal id="edit_issue_modal" title="Edit Issue">
    <form id="edit_issue_form" class="space-y-4">
        <input type="hidden" name="issueId" id="edit_issue_id" />
        <Input name="title" label="Title" id="edit_issue_title" required />
        
        <div>
            <label class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1">Description</label>
            <textarea name="description" id="edit_issue_description" rows="3" class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50"></textarea>
        </div>

        <div>
            <label class="block text-sm font-medium text-ink-600 dark:text-ink-300 mb-1">Priority</label>
            <select name="priority" id="edit_issue_priority" class="w-full rounded-xl bg-surface-50 dark:bg-ink-900 border border-ink-200 dark:border-ink-700 px-3 py-2 text-sm text-ink-900 dark:text-ink-100 focus:outline-none focus:ring-2 focus:ring-peach-500/50">
                <option value="Low">Low</option>
                <option value="Medium">Medium</option>
                <option value="High">High</option>
            </select>
        </div>
        
        <div class="flex justify-between pt-4 border-t border-ink-100 dark:border-ink-700 mt-4">
            <button type="button" class="text-red-600 hover:text-red-700 text-sm font-medium" onclick="deleteIssue()">Delete Issue</button>
            <div class="flex gap-2">
                <Button variant="secondary" onclick="document.getElementById('edit_issue_modal').close()">Cancel</Button>
                <Button type="submit">Save Changes</Button>
            </div>
        </div>
    </form>
  </Modal>

  <!-- Create List Modal -->
  <Modal id="create_list_modal" title="Create New List">
    <form id="create_list_form" class="space-y-6">
      <Input
        name="title"
        label="List Title"
        placeholder="e.g. Testing, Blocked"
        required
      />

      <div>
        <label class="text-sm font-medium text-ink-600 dark:text-ink-300 ml-1 mb-2 block">
          List color
        </label>

        <div class="flex flex-wrap gap-2">
          {colorOptions.map((c, i) => (
            <label class="cursor-pointer">
              <input
                type="radio"
                name="color"
                value={c}
                class="peer sr-only"
                checked={i === 0 ? true : undefined}
              />
              <div
                class="w-7 h-7 rounded-full
                       ring-1 ring-ink-200/70 dark:ring-ink-700/60
                       peer-checked:ring-2 peer-checked:ring-peach-300/70
                       peer-checked:ring-offset-2 peer-checked:ring-offset-surface-50
                       dark:peer-checked:ring-offset-ink-900
                       transition"
                style={`background-color: ${c}`}
                aria-label={`Color ${c}`}
              ></div>
            </label>
          ))}
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <Button
          variant="ghost"
          type="button"
          onclick="document.getElementById('create_list_modal').close()"
        >
          Cancel
        </Button>
        <Button type="submit">Create list</Button>
      </div>
    </form>
  </Modal>

  <!-- Edit List Modal -->
  <Modal id="edit_list_modal" title="Edit List">
    <form id="edit_list_form" class="space-y-6">
      <input type="hidden" name="listId" id="edit_list_id" />

      <Input
        name="title"
        id="edit_list_title"
        label="List Title"
        required
      />

      <div>
        <label class="text-sm font-medium text-ink-600 dark:text-ink-300 ml-1 mb-2 block">
          List color
        </label>

        <div class="flex flex-wrap gap-2">
          {colorOptions.map((c) => (
            <label class="cursor-pointer">
              <input type="radio" name="color" value={c} class="peer sr-only" />
              <div
                class="w-7 h-7 rounded-full
                       ring-1 ring-ink-200/70 dark:ring-ink-700/60
                       peer-checked:ring-2 peer-checked:ring-peach-300/70
                       peer-checked:ring-offset-2 peer-checked:ring-offset-surface-50
                       dark:peer-checked:ring-offset-ink-900
                       transition"
                style={`background-color: ${c}`}
                aria-label={`Color ${c}`}
              ></div>
            </label>
          ))}
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <Button
          variant="ghost"
          type="button"
          onclick="document.getElementById('edit_list_modal').close()"
        >
          Cancel
        </Button>
        <Button type="submit">Save changes</Button>
      </div>
    </form>
  </Modal>
</AppLayout>

<script define:vars={{ projectId: projectId, issues }}>
  window.projectId = projectId;
  window.issues = issues;

  // List Creation
  const createForm = document.getElementById("create_list_form");
  createForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);

    try {
      const res = await fetch(`/api/projects/${projectId}/lists`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (res.ok) window.location.reload();
      else alert("Failed to create list");
    } catch (err) {
      console.error(err);
      alert("Error creating list");
    }
  });

  // Edit List
  const editForm = document.getElementById("edit_list_form");
  editForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);
    const listId = data.listId;

    try {
      const res = await fetch(`/api/projects/${projectId}/lists/${listId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (res.ok) window.location.reload();
      else alert("Failed to update list");
    } catch (err) {
      console.error(err);
      alert("Error updating list");
    }
  });

  window.openEditListModal = (id, title, color) => {
    closeAllMenus();

    const modal = document.getElementById("edit_list_modal");
    const form = document.getElementById("edit_list_form");

    document.getElementById("edit_list_id").value = id;
    document.getElementById("edit_list_title").value = title;

    const colorRadio = form.querySelector(
      `input[name="color"][value="${color}"]`,
    );
    if (colorRadio) colorRadio.checked = true;

    modal.showModal();
  };

  // Menu Handling
  window.toggleMenu = (e, btn) => {
    e.preventDefault();
    e.stopPropagation();

    const dropdown = btn.nextElementSibling;
    if (!dropdown) return;

    const willOpen = dropdown.classList.contains("hidden");
    closeAllMenus();
    if (willOpen) dropdown.classList.remove("hidden");
  };

  function closeAllMenus() {
    document
      .querySelectorAll(".menu-dropdown")
      .forEach((el) => el.classList.add("hidden"));
  }

  document.addEventListener("click", (e) => {
    if (!e.target.closest(".menu-container")) closeAllMenus();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeAllMenus();
  });

  // Delete List
  window.deleteList = async (listId) => {
    if (!confirm("Are you sure you want to delete this list?")) return;
    try {
      const res = await fetch(`/api/projects/${projectId}/lists/${listId}`, {
        method: "DELETE",
      });
      if (res.ok) window.location.reload();
      else alert("Failed to delete list");
    } catch (err) {
      console.error(err);
      alert("Error deleting list");
    }
  };

  // Drag & drop lists
  const container = document.getElementById("board-lists");
  let draggable = null;

  // Initial setup: ensure list containers are properly configured
  // HTML5 DnD requires draggable="true" on the element, but we want to restrict
  // drag initiation to the handle. A common pattern is to use mousedown on the handle
  // to set draggable=true on the container, and reset it otherwise.
  
  document.addEventListener('mousedown', (e) => {
      const target = e.target;
      // We are looking for clicks within our list containers
      const listEl = target.closest('.list-container');
      if (!listEl) return;

      // Check if the click started on a handle (or inside it)
      const handle = target.closest('.handle');

      if (handle) {
          listEl.setAttribute('draggable', 'true');
      } else {
          // If clicking elsewhere (e.g. content, buttons), disable drag
          listEl.setAttribute('draggable', 'false');
      }
  });

  if (container) {
      container.addEventListener("dragstart", (e) => {
        // e.target is the element being dragged (the list-container)
        const target = e.target;
        if (!target.classList || !target.classList.contains('list-container')) return;
        
        draggable = target;
        draggable.classList.add("opacity-50");
        e.dataTransfer.effectAllowed = "move";
        // Required for Firefox
        e.dataTransfer.setData('text/plain', draggable.dataset.id);
      });

      container.addEventListener("dragend", async (e) => {
        if (!draggable) return;
        draggable.classList.remove("opacity-50");
        draggable.removeAttribute('draggable'); // Reset state
        
        // Calculate new order
        const listIds = Array.from(
          container.querySelectorAll(".list-container"),
        ).map((el) => el.getAttribute('data-id'));

        try {
          await fetch(`/api/projects/${projectId}/lists`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ listIds }),
          });
        } catch (err) {
          console.error("Failed to save order", err);
        }

        draggable = null;
      });

      container.addEventListener("dragover", (e) => {
        e.preventDefault();
        if (!draggable) return;

        const afterElement = getDragAfterElement(container, e.clientX);
        const newListBtn = container.querySelector("button[onclick*='create_list_modal']");
        
        if (afterElement == null) {
            if (newListBtn) {
                container.insertBefore(draggable, newListBtn);
            } else {
                container.appendChild(draggable);
            }
        } else {
            container.insertBefore(draggable, afterElement);
        }
      });
  }

  function getDragAfterElement(container, x) {
    const draggableElements = [
      ...container.querySelectorAll(".list-container:not(.opacity-50)"),
    ];

    return draggableElements.reduce(
      (closest, child) => {
        const box = child.getBoundingClientRect();
        const offset = x - box.left - box.width / 2;
        if (offset < 0 && offset > closest.offset) {
          return { offset: offset, element: child };
        }
        return closest;
      },
      { offset: Number.NEGATIVE_INFINITY, element: null },
    ).element;
  }
</script>

<script>
  // Create Issue
  window.openCreateIssueModal = (listId) => {
    document.getElementById('create_issue_list_id').value = listId;
    document.getElementById('create_issue_modal').showModal();
  };

  const createIssueForm = document.getElementById('create_issue_form');
  createIssueForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData);
    
    try {
        const res = await fetch(`/api/projects/${window.projectId}/issues`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        if (res.ok) window.location.reload();
        else alert('Failed to create issue');
    } catch (err) {
        console.error(err);
        alert('Error creating issue');
    }
  });

  // Edit Issue
  window.openEditIssueModal = (issueId) => {
      const issue = window.issues.find(i => i._id === issueId);
      if (!issue) return;
      
      const modal = document.getElementById('edit_issue_modal');
      // Populate form
      document.getElementById('edit_issue_id').value = issue._id;
      document.getElementById('edit_issue_title').value = issue.title;
      document.getElementById('edit_issue_description').value = issue.description || '';
      document.getElementById('edit_issue_priority').value = issue.priority;

      modal.showModal();
  };

  const editIssueForm = document.getElementById('edit_issue_form');
  editIssueForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);
      const issueId = data.issueId;
      
      try {
          const res = await fetch(`/api/projects/${window.projectId}/issues/${issueId}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
          });
          if (res.ok) window.location.reload();
          else alert('Failed to update issue');
      } catch (err) {
          console.error(err);
          alert('Error updating issue');
      }
  });

  window.deleteIssue = async () => {
      const issueId = document.getElementById('edit_issue_id').value;
      if (!confirm('Are you sure?')) return;
      
      try {
          const res = await fetch(`/api/projects/${window.projectId}/issues/${issueId}`, {
              method: 'DELETE'
          });
          if (res.ok) window.location.reload();
          else alert('Failed to delete issue');
      } catch (err) {
          console.error(err);
          alert('Error deleting issue');
      }
  };

  // Issue Drag and Drop
  const issueContainers = document.querySelectorAll('.list-body');
  let draggedIssue = null;

  issueContainers.forEach(container => {
      container.addEventListener('dragstart', (e) => {
          if (!e.target.classList.contains('issue-card')) return;
          e.stopPropagation(); // Prevent list drag
          draggedIssue = e.target;
          draggedIssue.classList.add('opacity-50');
          e.dataTransfer.effectAllowed = 'move';
          e.dataTransfer.setData('text/plain', draggedIssue.dataset.issueId); // Firefox requires data
      });

      container.addEventListener('dragend', async (e) => {
          if (!draggedIssue) return;
          e.stopPropagation();
          draggedIssue.classList.remove('opacity-50');
          
          const issueId = draggedIssue.dataset.issueId;
          const closestListBody = draggedIssue.closest('.list-body');
          if (!closestListBody) return;

          const newListId = closestListBody.dataset.listId;
          
          const siblings = [...closestListBody.children].filter(c => c.classList.contains('issue-card'));
          const newIndex = siblings.indexOf(draggedIssue);
          
          try {
             await fetch(`/api/projects/${window.projectId}/issues/${issueId}`, {
                 method: 'PUT',
                 headers: { 'Content-Type': 'application/json' },
                 body: JSON.stringify({
                     listId: newListId,
                     order: newIndex
                 })
             });
          } catch (err) {
             console.error('Failed to move issue', err);
             alert('Failed to move issue');
          }
          
          draggedIssue = null;
      });

      container.addEventListener('dragover', (e) => {
          if (!draggedIssue) return;
          e.preventDefault();
          e.stopPropagation();

          const afterElement = getDragAfterIssue(container, e.clientY);
          if (afterElement == null) {
              container.appendChild(draggedIssue);
          } else {
              container.insertBefore(draggedIssue, afterElement);
          }
      });
  });

  function getDragAfterIssue(container, y) {
      const draggableElements = [...container.querySelectorAll('.issue-card:not(.opacity-50)')];

      return draggableElements.reduce((closest, child) => {
          const box = child.getBoundingClientRect();
          const offset = y - box.top - box.height / 2;
          if (offset < 0 && offset > closest.offset) {
              return { offset: offset, element: child };
          }
          return closest;
      }, { offset: Number.NEGATIVE_INFINITY }).element;
  }
</script>

<script>
  window.filterIssues = () => {
     const search = document.getElementById('issue-search').value.toLowerCase();
     const priority = document.getElementById('issue-priority-filter').value;
     
     const cards = document.querySelectorAll('.issue-card');
     
     cards.forEach(card => {
         const issueId = card.dataset.issueId;
         const issue = window.issues.find(i => i._id === issueId);
         
         if (!issue) return;
         
         const matchesSearch = issue.title.toLowerCase().includes(search) || (issue.description && issue.description.toLowerCase().includes(search));
         const matchesPriority = !priority || issue.priority === priority;
         
         if (matchesSearch && matchesPriority) {
             card.classList.remove('hidden');
         } else {
             card.classList.add('hidden');
         }
     });
  };
</script>
